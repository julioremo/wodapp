{
  "$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    },
    "enabled": true
  },
  "files": {
    "ignoreUnknown": false
  },
  "formatter": {
    "attributePosition": "auto",
    "bracketSameLine": true,
    "bracketSpacing": true,
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "lineEnding": "lf",
    "lineWidth": 100,
    "useEditorconfig": true
  },
  "html": {
    "experimentalFullSupportEnabled": true,
    "formatter": {
      "bracketSameLine": true,
      "enabled": true,
      "indentScriptAndStyle": false,
      "selfCloseVoidElements": "always"
    }
  },
  "javascript": {
    "formatter": {
      "arrowParentheses": "always",
      "attributePosition": "auto",
      "bracketSameLine": true,
      "bracketSpacing": true,
      "expand": "auto",
      "indentWidth": 2,
      "jsxQuoteStyle": "double",
      "operatorLinebreak": "before",
      "quoteProperties": "asNeeded",
      "quoteStyle": "double",
      "trailingCommas": "none"
    }
  },
  "linter": {
    "rules": {
      "nursery": {
        "useSortedClasses": {
          "level": "info",
          "options": {
            "attributes": ["class", "className"],
            "functions": ["clsx", "cva", "tw"]
          }
        }
      }
    }
  },
  "overrides": [
    {
      "includes": ["*.svelte"]
    }
  ],
  "vcs": {
    "clientKind": "git",
    "enabled": true,
    "useIgnoreFile": true
  }
}
