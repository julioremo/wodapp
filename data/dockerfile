# Use a lightweight Python base image
FROM python:3.12.13-slim

# Copy the uv binary directly from the official image
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# Set the working directory inside the container
WORKDIR /app

# Copy only the dependency files first to leverage Docker layer caching
COPY pyproject.toml uv.lock ./

# Install dependencies using uv. 
# This creates an isolated virtual environment inside the container.
RUN uv sync --frozen --no-dev --no-install-project

# Now copy the rest of your Python worker code
COPY . .

# Expose the port your FastAPI server runs on
EXPOSE 8000

# Start the application using uv to run uvicorn within the managed environment
# Adjust 'main:app' if your FastAPI instance is named differently or in a sub-module
CMD ["uv", "run", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]